# GROM SERVER - Variaveis operacionais nao secretas
# Copiar para /etc/grom/grom.env no servidor e ajustar se necessario.

GROM_CONTACT_EMAIL=grom.servidor@gmail.com
GROM_ALERT_EMAIL=grom.servidor@gmail.com
GROM_DOMAIN=grom.seg.br
GROM_APP_DOMAIN=grom.seg.br
GROM_SMTP_USER=grom.servidor@gmail.com
GROM_SMTP_FROM=grom.servidor@gmail.com

# Segredo local: definir apenas em /etc/grom/grom.env no servidor.
# Nunca commitar segredos.
# MYSQL_ROOT_PASS=
# GROM_SEG_PASS=
# GROM_WEB_PASS=
# GROM_DOC_PASS=
# GROM_BACKUP_PASS=
# BORG_PASSPHRASE=
# GROM_SMTP_APP_PASS=

# Backup externo opcional via rclone crypt.
# Configurar o remote localmente no CT112 antes de ativar.
GROM_RCLONE_REMOTE=gromdrive_crypt:grom-server-backups
GROM_RCLONE_SOURCE=/mnt/backup

# Grom_Security notificacoes externas.
# Manter dry-run ate validar destinatarios e conteudo LGPD.
GROM_SECURITY_NOTIFICATION_CHANNELS=telegram,email
GROM_SECURITY_NOTIFICATION_DRY_RUN=true

# Segredos/destinatarios locais futuros, nunca commitar valores reais.
# GROM_SECURITY_TELEGRAM_BOT_TOKEN=
# GROM_SECURITY_TELEGRAM_CHAT_ID=
# GROM_SECURITY_WHATSAPP_PROVIDER_TOKEN=
# GROM_SECURITY_SMS_PROVIDER_TOKEN=
GROM_SECURITY_SMTP_HOST=smtp.gmail.com
GROM_SECURITY_SMTP_PORT=587
GROM_SECURITY_SMTP_USERNAME=grom.servidor@gmail.com
GROM_SECURITY_SMTP_FROM=grom.servidor@gmail.com
# GROM_SECURITY_SMTP_PASSWORD={SENHA_DE_APP_LOCAL}
# GROM_SECURITY_ALERT_EMAIL_TO={DESTINATARIO_AUTORIZADO}
