# =============================================================================
# GROM SERVER - .gitignore
# =============================================================================

# Senhas e credenciais
*.credentials
*.key
*.pem
*.secret
.env
.env.*
!.env.example
grom.env
*.env.local

# Chaves SSH
id_rsa
id_ed25519
*.pub

# Backups locais
*.bak
*.old
*.orig
*.swp
*~

# Artefatos gerados localmente
downloads/
dist/

# Logs
*.log
logs/

# Diretórios de dados
data/
!apps/grom-seg/public/server/data/
!apps/grom-seg/public/server/data/status.json
dumps/

# Cache
__pycache__/
*.pyc
*.pyo
.cache/
node_modules/
vendor/

# IDE
.vscode/
.idea/
*.sublime-*

# OS
Thumbs.db
.DS_Store
desktop.ini

# Arquivos de lock de banco
*.lck

# Borg passphrase
.borg_passphrase
.grom_backup_env
.grom_mysql_credentials
borg-keys/
